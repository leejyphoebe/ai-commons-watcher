ARG CUDA_VERSION=12.8.0
#################### vLLM installation IMAGE ####################
# image with vLLM installed
FROM nvidia/cuda:${CUDA_VERSION}-devel-ubuntu22.04 AS vllm-base
ARG PYTHON_VERSION=3.12
WORKDIR /vllm-workspace
ENV DEBIAN_FRONTEND=noninteractive
ARG TARGETPLATFORM

# Add an ARG for MAX_JOBS for the vLLM build
ARG VLLM_MAX_JOBS=8 # Default to 8, can be overridden at build time

# Install Python and other dependencies
RUN echo 'tzdata tzdata/Areas select America' | debconf-set-selections \
    && echo 'tzdata tzdata/Zones/America select Los_Angeles' | debconf-set-selections \
    && apt-get update -y \
    && apt-get install -y --no-install-recommends \
        software-properties-common \
        git \
        curl \
        wget \
        sudo \
        vim \
        ccache \
        ffmpeg \
        libsm6 \
        libxext6 \
        libgl1 \
    && add-apt-repository -y ppa:deadsnakes/ppa \
    && apt-get update -y \
    && apt-get install -y --no-install-recommends \
        python${PYTHON_VERSION} \
        python${PYTHON_VERSION}-dev \
        python${PYTHON_VERSION}-venv \
        libibverbs-dev \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python${PYTHON_VERSION} 1 \
    && update-alternatives --set python3 /usr/bin/python${PYTHON_VERSION} \
    && ln -sf /usr/bin/python${PYTHON_VERSION}-config /usr/bin/python3-config \
    && curl -sS https://bootstrap.pypa.io/get-pip.py | python${PYTHON_VERSION} \
    && python3 --version \
    && python3 -m pip --version

RUN --mount=type=cache,target=/root/.cache/pip \
    python3 -m pip install uv

RUN if [ -d /usr/local/cuda-$(echo $CUDA_VERSION | cut -d. -f1,2)/compat/ ]; then \
        ldconfig /usr/local/cuda-$(echo $CUDA_VERSION | cut -d. -f1,2)/compat/; \
    else \
        echo "CUDA compat directory not found, skipping ldconfig."; \
    fi

# Install PyTorch cu128 nightly BEFORE vLLM for all platforms
RUN --mount=type=cache,target=/root/.cache/pip \
    echo "Installing PyTorch cu128 nightly..." && \
    uv pip install --system torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu128


# The TARGETPLATFORM specific PyTorch installation block for arm64 is now likely redundant
# if the general installation above correctly handles arm64 by finding a suitable wheel
# from the cu128 index. If the cu128 index does NOT have arm64 wheels, or if arm64
# needs a *different* PyTorch source/version, then the conditional block would need
# to be re-enabled and potentially modified.
#
# Original arm64 specific block (now commented out):
# RUN --mount=type=cache,target=/root/.cache/pip \
#     if [ "$TARGETPLATFORM" = "linux/arm64" ]; then \
#         echo "Installing PyTorch for linux/arm64..." ; \
#         uv pip install --system torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu128;  \
#     fi

# Clone and install vLLM
# NOTE ON vLLM INSTALLATION METHOD:
# The current command installs `vllm==0.8.5.post1` from PyPI.
# The `git clone` is performed, but the cloned source is NOT used for an editable install with this command.
#
# IF YOU WANT AN EDITABLE INSTALL (where changes to /vllm-workspace/vllm are reflected):
# Change the `uv pip install ... vllm==0.8.5.post1` line below to:
#   MAX_JOBS=${VLLM_MAX_JOBS} uv pip install --system --editable . && \
# This will build and install vLLM from the cloned source in editable mode.

# Install vLLM using pip
RUN --mount=type=cache,target=/root/.cache/pip \
    echo "Installing vLLM 0.9.0.1..." && \
    uv pip install --system vllm==0.9.0.1 && \
    python3 -c "import vllm; print('vLLM version:', vllm.__version__)"

# RUN --mount=type=cache,target=/root/.cache/pip \
#     echo "Installing vLLM 0.8.5.post1..." && \
#     uv pip install --system vllm==0.8.5.post1 --extra-index-url https://download.pytorch.org/whl/cu128 && \
#     python3 -c "import vllm; print('vLLM version:', vllm.__version__)"

# # Build vLLM from source with existing PyTorch
# RUN --mount=type=cache,target=/root/.cache/pip \
#     git clone -b v0.8.5.post1 https://github.com/vllm-project/vllm.git && \
#     cd vllm && \
#     MAX_JOBS=${VLLM_MAX_JOBS} VLLM_USE_PRECOMPILED=0 uv pip install --system -e . && \
#     python3 -c "import vllm; print('vLLM version:', vllm.__version__)"

CMD ["/bin/bash"]