#!/bin/bash
#PBS -l select=1:ngpus=1
#PBS -l walltime=02:00:00
#PBS -j oe
#PBS -N download_vllm_sif
#PBS -o ./logs/download_vllm_sif.log

rm /scratch/users/ntu/$USER/sif_images/vllm.sif
module load singularity
export SINGULARITY_CACHEDIR=/scratch/users/ntu/$USER/.singularity
singularity pull /scratch/users/ntu/$USER/sif_images/vllm.sif docker://broccolin/vllm-nscc-edit:latest

